# Credenziali dell'app creata su https://developers.tiktok.com
# (in sviluppo usa quelle della Sandbox, non della Production)
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# URL pubblico HTTPS con cui apri l'app (es. tunnel ngrok).
# Il redirect URI da registrare su TikTok è: {APP_URL}/api/auth/callback
APP_URL=

# Postgres Neon (storicizzazione robusta di snapshot/salvati/note per utente).
# Opzionale: se assente, l'app ripiega su filesystem + localStorage.
# Crea un progetto gratis su https://neon.tech e incolla la "pooled connection
# string" (deve contenere ?sslmode=require).
DATABASE_URL=
